#!/usr/bin/env bash
# wb-coord — multi-session presence + monitor (C).
#
# Every Claude Code tab is its own process; this is how they see each other.
# State lives under .claude/locks/ at the workspace root.
#
#   wb-coord ping [label]      register/refresh THIS session's heartbeat
#   wb-coord who               list live sessions (the at-a-glance monitor)
#   wb-coord status            who + held locks + overlap/conflict warnings
#   wb-coord claim <key...>    declare task/file keys this session is working on
#   wb-coord claims [key]      list live claims, or check if <key> is claimed by another (exit 0/1)
#   wb-coord release [path...] drop claims (all if none given)
#   wb-coord prune             remove stale session files
#   wb-coord whoami            print this session's id
#
# Agents: run `wb-coord ping <label>` at session start and after big edits,
# and `wb-coord status` before a shared-repo commit. Look, don't ask.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
. "$DIR/lib.sh"

wb_ensure_dirs
sid="$(wb_sid)"
sfile="$WB_SESSIONS_DIR/$sid.json"

# repo identity for a given dir: name relative to workspace root, or "workspace"
repo_name() {
  local top; top="$(git -C "${1:-$PWD}" rev-parse --show-toplevel 2>/dev/null || true)"
  [ -z "$top" ] && { echo "-"; return; }
  [ "$top" = "$WB_ROOT" ] && { echo "workspace"; return; }
  printf '%s\n' "${top#"$WB_ROOT"/}"
}
git_branch() { git -C "${1:-$PWD}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "-"; }
staged_count() { git -C "${1:-$PWD}" diff --cached --name-only 2>/dev/null | grep -c . || true; }
dirty_count()  { git -C "${1:-$PWD}" status --porcelain 2>/dev/null | grep -c . || true; }

cmd_ping() {
  # --throttle N: no-op if our heartbeat is younger than N seconds (used by the
  # PostToolUse auto-ping hook so it costs ~nothing on every tool call).
  if [ "${1:-}" = "--throttle" ]; then
    local win="${2:-20}"; shift 2 || true
    if [ -f "$sfile" ]; then
      local last; last="$(wb_json_get "$sfile" heartbeat_epoch || echo 0)"
      [ -n "$last" ] && [ $(( $(wb_now) - last )) -lt "$win" ] && return 0
    fi
  fi
  local label="${1:-${WB_LABEL:-}}"
  local cwd; cwd="$(pwd -P)"
  local claims=""; [ -f "$sfile" ] && claims="$(wb_json_get "$sfile" claims || true)"
  local started; started="$(wb_json_get "$sfile" started_at 2>/dev/null || true)"; [ -z "$started" ] && started="$(wb_now_iso)"
  printf '{"sid":"%s","label":"%s","pid":%s,"host":"%s","cwd":"%s","repo":"%s","branch":"%s","staged":%s,"dirty":%s,"started_at":"%s","heartbeat_iso":"%s","heartbeat_epoch":%s,"claims":"%s"}\n' \
    "$sid" "$label" "$$" "$(hostname -s 2>/dev/null || echo host)" "$cwd" "$(repo_name "$cwd")" "$(git_branch "$cwd")" \
    "$(staged_count "$cwd")" "$(dirty_count "$cwd")" "$started" "$(wb_now_iso)" "$(wb_now)" "$claims" > "$sfile"
  echo "${WB_GRN}● coord:${WB_RST} $(wb_sid_short "$sid")${label:+ ($label)} pinged."
}

# iterate live session files; calls `emit <file>` for each fresh one
each_live() {
  local f hb
  shopt -s nullglob
  for f in "$WB_SESSIONS_DIR"/*.json; do
    hb="$(wb_json_get "$f" heartbeat_epoch || echo 0)"
    wb_is_fresh "$hb" "$WB_SESSION_TTL" && "$1" "$f"
  done
}

print_row() {
  local f="$1" me=""; [ "$(wb_json_get "$f" sid)" = "$sid" ] && me="${WB_BOLD} (you)${WB_RST}"
  local age=$(( $(wb_now) - $(wb_json_get "$f" heartbeat_epoch || echo 0) ))
  printf '  %s%-12s%s  %-16s repo=%-14s br=%-16s staged=%s dirty=%s  %ds ago%s\n' \
    "$WB_BOLD" "$(wb_sid_short "$(wb_json_get "$f" sid)")" "$WB_RST" \
    "$(wb_json_get "$f" label)" "$(wb_json_get "$f" repo)" "$(wb_json_get "$f" branch)" \
    "$(wb_json_get "$f" staged)" "$(wb_json_get "$f" dirty)" "$age" "$me"
}

cmd_who() {
  local n=0; each_live print_row >/tmp/.bbwho.$$ 2>/dev/null || true
  n="$(grep -c . /tmp/.bbwho.$$ 2>/dev/null || echo 0)"
  echo "${WB_BOLD}Live sessions (≤${WB_SESSION_TTL}s):${WB_RST}"
  [ "$n" -gt 0 ] && cat /tmp/.bbwho.$$ || echo "  (none — run 'wb-coord ping')"
  rm -f /tmp/.bbwho.$$
}

cmd_status() {
  cmd_who
  echo ""
  echo "${WB_BOLD}Held locks:${WB_RST}"
  shopt -s nullglob; local any=0
  for l in "$WB_LOCKS_DIR"/*.lock; do
    local hb; hb="$(wb_json_get "$l" heartbeat_epoch || echo 0)"
    if wb_is_fresh "$hb" "$WB_LOCK_TTL"; then
      any=1; printf '  %s%s%s held by %s (%ds ago)\n' "$WB_YEL" "$(basename "$l" .lock)" "$WB_RST" \
        "$(wb_sid_short "$(wb_json_get "$l" holder)")" "$(( $(wb_now) - hb ))"
    fi
  done
  [ "$any" = 0 ] && echo "  (none)"
  echo ""
  echo "${WB_BOLD}Claims (live sessions):${WB_RST}"
  cmd_claims
  echo ""
  echo "${WB_BOLD}Overlap check:${WB_RST}"
  # Warn when >1 live session sits in the same repo with uncommitted changes.
  awk_overlap
}

# Detect repos where >1 live session has staged/dirty changes → sweep risk.
awk_overlap() {
  declare -a repos; local f r staged dirty
  : > /tmp/.bbov.$$
  each_live _ov_collect 2>/dev/null || true
  # group by repo, count sessions with changes
  sort /tmp/.bbov.$$ 2>/dev/null | awk '{c[$1]++} END{for(r in c) if(c[r]>1) print r" "c[r]}' > /tmp/.bbov2.$$
  if [ -s /tmp/.bbov2.$$ ]; then
    while read -r repo cnt; do
      echo "  ${WB_RED}⚠ $cnt live sessions have uncommitted changes in '$repo'${WB_RST} — commit with an explicit pathspec ('git commit -- <your files>') or use a worktree."
    done < /tmp/.bbov2.$$
  else
    echo "  ${WB_GRN}clear${WB_RST} — no repo has two live sessions with uncommitted changes."
  fi
  rm -f /tmp/.bbov.$$ /tmp/.bbov2.$$
}
_ov_collect() {
  local f="$1" st dy rp
  st="$(wb_json_get "$f" staged || echo 0)"; dy="$(wb_json_get "$f" dirty || echo 0)"
  rp="$(wb_json_get "$f" repo || echo -)"
  { [ "${st:-0}" -gt 0 ] 2>/dev/null || [ "${dy:-0}" -gt 0 ] 2>/dev/null; } && echo "$rp" >> /tmp/.bbov.$$
}

cmd_claim() {
  [ "$#" -gt 0 ] || { echo "usage: wb-coord claim <key...>" >&2; return 64; }
  [ -f "$sfile" ] || cmd_ping >/dev/null
  local cur new p tmp; cur="$(wb_json_get "$sfile" claims || true)"
  new="$cur"
  for p in "$@"; do
    case ";$new;" in *";$p;"*) continue ;; esac   # already claimed → skip (de-dup)
    new="${new:+$new;}$p"
  done
  tmp="$sfile.$$"
  if grep -q '"claims":' "$sfile"; then
    sed "s#\"claims\":\"[^\"]*\"#\"claims\":\"$new\"#" "$sfile" > "$tmp" && mv "$tmp" "$sfile"
  else
    # older session file without a claims field → insert one before the closing brace
    sed "s#}\$#,\"claims\":\"$new\"}#" "$sfile" > "$tmp" && mv "$tmp" "$sfile"
  fi
  if grep -qF "\"claims\":\"$new\"" "$sfile"; then
    echo "claimed: $*"
  else
    echo "wb-coord: claim write failed for $*" >&2; return 1
  fi
}

# list claims of all live sessions, or (with a key) check if it is claimed by ANOTHER live
# session: prints the holder and exits 0 if so, exits 1 if the key is free.
cmd_claims() {
  local want="${1:-}" found=0 f hb s cl
  shopt -s nullglob
  for f in "$WB_SESSIONS_DIR"/*.json; do
    hb="$(wb_json_get "$f" heartbeat_epoch || echo 0)"
    wb_is_fresh "$hb" "$WB_SESSION_TTL" || continue
    s="$(wb_json_get "$f" sid)"; cl="$(wb_json_get "$f" claims || true)"
    [ -n "$cl" ] || continue
    if [ -n "$want" ]; then
      case ";$cl;" in
        *";$want;"*)
          [ "$s" = "$sid" ] && continue
          echo "${WB_YEL}$want${WB_RST} claimed by ${WB_BOLD}$(wb_sid_short "$s")${WB_RST}"; found=1 ;;
      esac
    else
      printf '  %s%-12s%s  %s\n' "$WB_BOLD" "$(wb_sid_short "$s")" "$WB_RST" "$cl"; found=1
    fi
  done
  if [ -n "$want" ]; then
    [ "$found" = 1 ] && return 0 || { echo "$want is free"; return 1; }
  else
    [ "$found" = 1 ] || echo "  (no claims by live sessions)"
  fi
}
cmd_release() {
  [ -f "$sfile" ] || return 0
  local tmp="$sfile.$$"; sed "s#\"claims\":\"[^\"]*\"#\"claims\":\"\"#" "$sfile" > "$tmp" && mv "$tmp" "$sfile"
  echo "released claims for $(wb_sid_short "$sid")"
}

cmd_prune() {
  shopt -s nullglob; local removed=0 f hb
  for f in "$WB_SESSIONS_DIR"/*.json; do
    hb="$(wb_json_get "$f" heartbeat_epoch || echo 0)"
    wb_is_fresh "$hb" "$WB_SESSION_TTL" || { rm -f "$f"; removed=$((removed+1)); }
  done
  for l in "$WB_LOCKS_DIR"/*.lock; do
    hb="$(wb_json_get "$l" heartbeat_epoch || echo 0)"
    wb_is_fresh "$hb" "$WB_LOCK_TTL" || { rm -f "$l"; removed=$((removed+1)); }
  done
  echo "pruned $removed stale file(s)."
}

case "${1:-status}" in
  ping)    shift; cmd_ping "$@" ;;
  who)     cmd_who ;;
  status)  cmd_status ;;
  claim)   shift; cmd_claim "$@" ;;
  claims)  shift; cmd_claims "$@" ;;
  release) shift; cmd_release "$@" ;;
  prune)   cmd_prune ;;
  whoami)  echo "$sid" ;;
  *) echo "usage: wb-coord {ping|who|status|claim|claims|release|prune|whoami}" >&2; exit 64 ;;
esac
