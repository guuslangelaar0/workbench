{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workbench project config",
  "type": "object",
  "required": ["workbench", "project", "way_of_working", "lifecycle"],
  "properties": {
    "workbench": {
      "type": "object",
      "required": ["version", "initialized_at", "level"],
      "properties": {
        "version": { "type": "string" },
        "initialized_at": { "type": "string" },
        "level": { "enum": ["solo", "pair", "crew", "fleet"] },
        "hooks": {
          "type": "object",
          "required": ["mode", "version", "updated_at"],
          "properties": {
            "mode": { "enum": ["enabled", "disabled"] },
            "version": { "type": "string" },
            "updated_at": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    },
    "project": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string" },
        "mission": { "type": "string" },
        "launch_target": { "type": "string" },
        "kind": { "enum": ["existing", "greenfield"] },
        "topology": { "enum": ["single", "multi-repo"] },
        "repos": { "type": "array" },
        "prod": { "type": "object" }
      }
    },
    "way_of_working": {
      "type": "object",
      "required": ["models", "verification", "review", "parallelism", "enforcement", "continuity", "graphify", "codex", "remote", "inception_depth"],
      "properties": {
        "models": { "enum": ["leaner", "recommended", "better"] },
        "verification": { "enum": ["leaner", "recommended", "better"] },
        "review": { "enum": ["leaner", "recommended", "better"] },
        "parallelism": { "enum": ["leaner", "recommended", "better"] },
        "enforcement": { "enum": ["remind", "warn-default", "strict"] },
        "continuity": { "enum": ["leaner", "recommended", "better"] },
        "graphify": { "enum": ["off", "per-repo", "full"] },
        "codex": { "enum": ["off", "rescue-only", "full-lane"] },
        "remote": { "enum": ["off", "native", "telegram", "both"] },
        "inception_depth": { "enum": ["leaner", "recommended", "better"] }
      }
    },
    "dial_overrides": {
      "type": "object",
      "properties": {
        "team": { "type": "string" },
        "release": { "type": "string" },
        "decomposition": { "type": "string" },
        "architecture": { "type": "string" },
        "surfaces": { "type": "string" },
        "graphify": { "type": "string" },
        "loop_autonomy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["in_review_cap"],
      "properties": {
        "in_review_cap": { "type": "integer" }
      }
    }
  }
}
