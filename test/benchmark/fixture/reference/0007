roman_to_int() {
  local s="$1" total=0 i c v prev=0
  declare -A val=( [I]=1 [V]=5 [X]=10 [L]=50 [C]=100 [D]=500 [M]=1000 )
  for (( i=${#s}-1; i>=0; i-- )); do
    c="${s:$i:1}"; v=${val[$c]:-0}
    if [ "$v" -lt "$prev" ]; then total=$((total - v)); else total=$((total + v)); fi
    prev=$v
  done
  printf '%s\n' "$total"
}
